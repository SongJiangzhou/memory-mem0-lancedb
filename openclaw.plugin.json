{
  "id": "openclaw-mem0-lancedb",
  "name": "Mem0 + LanceDB Memory",
  "description": "Local-first OpenClaw memory plugin using LanceDB for recall and Mem0 for extraction and sync",
  "version": "0.1.0",
  "kind": "memory",
  "entry": "dist/src/index.js",
  "configSchema": {
    "type": "object",
    "properties": {
      "lancedbPath": {
        "type": "string",
        "default": "~/.openclaw/workspace/data/memory/lancedb"
      },
      "mem0": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["local", "remote", "disabled"],
            "default": "local"
          },
          "baseUrl": {
            "type": "string",
            "default": "http://127.0.0.1:8000"
          },
          "apiKey": {
            "type": "string",
            "default": ""
          },
          "llm": {
            "type": "object",
            "properties": {
              "provider": {
                "type": "string",
                "enum": ["openai", "gemini", "ollama", "deepseek"],
                "default": "deepseek"
              },
              "baseUrl": {
                "type": "string",
                "default": "https://api.deepseek.com"
              },
              "apiKey": {
                "type": "string",
                "default": ""
              },
              "model": {
                "type": "string",
                "default": "deepseek-chat"
              }
            }
          }
        }
      },
      "outboxDbPath": {
        "type": "string",
        "default": "~/.openclaw/workspace/data/memory/outbox.json"
      },
      "debug": {
        "type": "object",
        "properties": {
          "mode": {
            "type": "string",
            "enum": ["off", "debug"],
            "default": "off"
          }
        }
      },
      "autoRecall": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "topK": {
            "type": "number",
            "default": 5
          },
          "maxChars": {
            "type": "number",
            "default": 1400
          },
          "scope": {
            "type": "string",
            "enum": ["long-term", "all"],
            "default": "all"
          },
          "reranker": {
            "type": "object",
            "properties": {
              "provider": {
                "type": "string",
                "enum": ["local", "voyage", "none"],
                "default": "local"
              },
              "baseUrl": {
                "type": "string",
                "default": "https://api.voyageai.com/v1"
              },
              "apiKey": {
                "type": "string",
                "default": ""
              },
              "model": {
                "type": "string",
                "default": "rerank-2.5-lite"
              }
            }
          }
        }
      },
      "autoCapture": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "requireAssistantReply": {
            "type": "boolean",
            "default": true
          },
          "maxCharsPerMessage": {
            "type": "number",
            "default": 2000
          }
        }
      }
    }
  }
}
